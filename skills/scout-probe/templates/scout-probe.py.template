# === CONFIGURE: poll settings ===
POLL_INTERVAL_SECONDS = 5
POLL_TIMEOUT_SECONDS = 90  # Increase for slow EQS materialization (up to 90s in dev)


# ─── Auth ──────────────────────────────────────────────────────────────────────

def get_token(env: str, verbose: bool = False) -> str:
    """Source auth-helper.sh and return a bearer token for the target environment."""
    # === CONFIGURE: auth-helper.sh export variable name ===
    token_env_var = "{AUTH_TOKEN_ENV_VAR}"  # e.g. SUPERVISR_DEV_TOKEN, LLC_DEV_TOKEN

    script = f"source ~/.claude/scripts/auth-helper.sh {env} && echo ${token_env_var}"
    result = subprocess.run(
        ["bash", "-c", script],
        capture_output=True,
        text=True,
    )
    token = result.stdout.strip()
    if not token:
        print(f"[ERROR] Failed to provision auth token. stderr: {result.stderr}", file=sys.stderr)
        sys.exit(1)
    if verbose:
        print(f"[AUTH] Token provisioned (last 8 chars): ...{token[-8:]}")
    return token


# ─── Step 1: Extract source record ────────────────────────────────────────────

def extract_source_record(config: dict, token: str, verbose: bool = False) -> dict:
    """
    Pull one real record from the source system.
    Returns a dict with at minimum the key identifiers needed for entity creation
    and operation execution.
    """
    import urllib.request

    # === CONFIGURE: source extraction ===
    # Replace with the actual query/endpoint to fetch one record from {SOURCE_SYSTEM}.
    # Prefer fetching by a known stable identifier if you have one.
    # Otherwise fetch the most recent record and take the first result.
    #
    # Example for Retell API:
    #   url = f"{config['source_base_url']}/v2/list-calls?limit=1"
    #   ...
    #   return {"call_id": record["call_id"], "to_number": record["to_number"], ...}

    url = f"{config['source_base_url']}/{SOURCE_EXTRACTION_ENDPOINT}"
    req = urllib.request.Request(url, headers={"Authorization": f"Bearer {token}"})
    with urllib.request.urlopen(req) as resp:
        data = json.loads(resp.read())

    # === CONFIGURE: parse the response to extract key identifiers ===
    record = data["{RECORDS_KEY}"][0]  # e.g. data["calls"][0]
    extracted = {
        # === CONFIGURE: map source fields to identifiers ===
        "{IDENTIFIER_KEY_1}": record["{SOURCE_FIELD_1}"],  # e.g. "call_id": record["call_id"]
        "{IDENTIFIER_KEY_2}": record["{SOURCE_FIELD_2}"],  # e.g. "phone": record["to_number"]
    }

    if verbose:
        print(f"[SOURCE] Extracted record: {json.dumps(extracted, indent=2)}")
    return extracted


# ─── Step 2: Create scout entity in target ────────────────────────────────────

def create_scout_entity(config: dict, token: str, source_record: dict, dry_run: bool = False, verbose: bool = False) -> dict:
    """
    Create a minimal entity in the target system using the source record's identifiers.
    Returns the created entity's identifiers.
    Skip this step (return empty dict) if the operation itself creates the entity.
    """
    import urllib.request

    # === CONFIGURE: entity creation ===
    # Build the minimum payload required for the target system to accept the entity.
    # Include all fields the operation will check/filter on (status, partnerId, etc.).

    payload = {
        # === CONFIGURE: map source identifiers to target entity fields ===
        "{TARGET_FIELD_1}": source_record["{IDENTIFIER_KEY_1}"],
        "{TARGET_FIELD_2}": source_record["{IDENTIFIER_KEY_2}"],
        # Add all required fields here
    }

    if dry_run:
        print(f"[DRY-RUN] Would create scout entity: {json.dumps(payload, indent=2)}")
        return {"scout_id": "dry-run-id"}

    url = f"{config['target_base_url']}/{TARGET_CREATION_ENDPOINT}"
    req = urllib.request.Request(
        url,
        data=json.dumps(payload).encode(),
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    with urllib.request.urlopen(req) as resp:
        created = json.loads(resp.read())

    # === CONFIGURE: extract the created entity's identifier ===
    entity = {
        "scout_id": created["{CREATED_ENTITY_ID_FIELD}"],
    }

    if verbose:
        print(f"[TARGET] Created scout entity: {json.dumps(entity, indent=2)}")
    return entity


# ─── Step 3: Read baseline state ──────────────────────────────────────────────

