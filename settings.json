{
  "includeCoAuthoredBy": false,
  "alwaysThinkingEnabled": true,
  "enable_tool_search": true,
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "List",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(make:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(vercel:*)",
      "Bash(gh:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push:*)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Read(*.env*)",
      "Write(*.env*)",
      "Read(*secret*)",
      "Edit(*secret*)",
      "Write(*secret*)",
      "Read(*password*)",
      "Edit(*password*)",
      "Write(*password*)",
      "*(*.env*)",
      "*(*.pem)",
      "*(*.key)",
      "*(*.p12)",
      "*(.ssh/*)",
      "*(*_rsa*)"
    ]
  },
  "model": "sonnet",
  "autoMemoryEnabled": false,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_FILE_PATH=\"$CLAUDE_TOOL_INPUT_FILE_PATH\" /Users/gabrielamyot/.claude-shared-config/hooks/auto-index.sh"
          }
        ]
      }
    ]
  }
}