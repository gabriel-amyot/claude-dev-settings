# ─── Step 4: Execute the operation ────────────────────────────────────────────

def execute_operation(config: dict, token: str, source_record: dict, scout_entity: dict, dry_run: bool = False, verbose: bool = False) -> dict:
    """
    Execute the operation under test for the single scout record.
    Returns a dict with at least: status_code, response_body.
    """
    import urllib.request

    # === CONFIGURE: operation execution ===
    # This is the operation you are testing. Scope it to the scout record if possible.
    # Capture the full response — it is evidence but NOT the verdict.

    if dry_run:
        print(f"[DRY-RUN] Would execute operation against record: {source_record}")
        return {"status_code": 0, "response_body": "dry-run", "skipped": True}

    # === CONFIGURE: build the operation request ===
    payload = {
        # Map scout record identifiers to the operation's expected input format
        "{OPERATION_FIELD_1}": source_record["{IDENTIFIER_KEY_1}"],
    }

    url = f"{config['target_base_url']}/{OPERATION_ENDPOINT}"
    req = urllib.request.Request(
        url,
        data=json.dumps(payload).encode(),
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="{OPERATION_HTTP_METHOD}",  # POST, PUT, PATCH, etc.
    )

    try:
        with urllib.request.urlopen(req) as resp:
            body = resp.read().decode()
            result = {"status_code": resp.status, "response_body": body}
    except urllib.error.HTTPError as e:
        result = {"status_code": e.code, "response_body": e.read().decode(), "error": True}

    if verbose:
        print(f"[OPERATION] Response: {json.dumps(result, indent=2)}")
    return result


# ─── Step 5: Poll-retry for materialization ────────────────────────────────────

def poll_for_state_change(config: dict, token: str, source_record: dict, scout_entity: dict, baseline: dict, verbose: bool = False) -> tuple[dict | None, int, float]:
    """
    Poll the read path until state changes from baseline or timeout.
    Returns (final_state, poll_count, elapsed_seconds).
    """
    start = time.monotonic()
    polls = 0

    while True:
        elapsed = time.monotonic() - start
        if elapsed >= POLL_TIMEOUT_SECONDS:
            if verbose:
                print(f"[POLL] Timeout after {elapsed:.1f}s ({polls} polls)")
            break

        polls += 1
        current = _query_read_path(config, token, source_record, scout_entity, verbose=False)

        if verbose:
            print(f"[POLL #{polls}] {elapsed:.1f}s — state: {json.dumps(current, indent=2)}")

        # === CONFIGURE: change detection ===
        # Replace with the actual field(s) you expect to change after the operation.
        # Example: if you expect status to change from "NEW" to "CONTACTED":
        #   baseline_val = (baseline or {}).get("status")
        #   current_val = (current or {}).get("status")
        #   if current_val != baseline_val and current_val == "CONTACTED":
        #       return current, polls, elapsed

        baseline_val = (baseline or {}).get("{EXPECTED_CHANGE_FIELD}")
        current_val = (current or {}).get("{EXPECTED_CHANGE_FIELD}")
        if current_val is not None and current_val != baseline_val:
            if verbose:
                print(f"[POLL] State changed at poll #{polls} ({elapsed:.1f}s)")
            return current, polls, elapsed

        time.sleep(POLL_INTERVAL_SECONDS)

    final = _query_read_path(config, token, source_record, scout_entity, verbose=False)
    return final, polls, time.monotonic() - start


# ─── Step 6: Compare states and emit verdict ──────────────────────────────────

def compare_states(baseline: dict | None, final: dict | None) -> dict:
    """
    Compute the diff between baseline and final state.
    Returns a dict of changed fields: {field: {before, after}}.
    """
    if baseline is None and final is None:
        return {}
    if baseline is None:
        return {k: {"before": None, "after": v} for k, v in (final or {}).items()}
    if final is None:
        return {k: {"before": v, "after": None} for k, v in (baseline or {}).items()}

    diff = {}
    all_keys = set(baseline.keys()) | set(final.keys())
    for key in all_keys:
        b = baseline.get(key)
        f = final.get(key)
        if b != f:
            diff[key] = {"before": b, "after": f}
    return diff


def is_pass(diff: dict, operation_result: dict) -> bool:
    """
    Determine PASS/FAIL based on diff and operation result.
    A PASS requires:
      1. The operation did not error (status < 400).
      2. The expected field(s) changed to the expected value(s).
    """
    if operation_result.get("skipped"):
        return True  # dry-run always passes structurally

    if operation_result.get("error") or operation_result.get("status_code", 0) >= 400:
        return False

    # === CONFIGURE: PASS condition ===
    # Replace with the actual field and expected value.
    # Example: diff must include "status" changing to "CONTACTED"
    #   return diff.get("status", {}).get("after") == "CONTACTED"

    return "{EXPECTED_CHANGE_FIELD}" in diff and diff["{EXPECTED_CHANGE_FIELD}"]["after"] == "{EXPECTED_VALUE}"


# ─── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Scout probe for {OPERATION_NAME}")
    parser.add_argument("--env", choices=["dev", "uat"], default="dev", help="Target environment")
    parser.add_argument("--dry-run", action="store_true", help="Print what would happen without executing")
    parser.add_argument("--verbose", action="store_true", help="Print detailed step output")
    args = parser.parse_args()

    config = ENV_CONFIG[args.env]

    print(f"\n=== Scout Probe: {'{OPERATION_NAME}'} | env={args.env} | {datetime.now(timezone.utc).isoformat()} ===\n")

    # Step 1: Auth
    token = get_token(args.env, verbose=args.verbose)

    # Step 2: Extract source record
    print("[1/6] Extracting source record...")
    source_record = extract_source_record(config, token, verbose=args.verbose)

    # Step 3: Create scout entity
    print("[2/6] Creating scout entity in target system...")
    scout_entity = create_scout_entity(config, token, source_record, dry_run=args.dry_run, verbose=args.verbose)

    # Step 4: Establish baseline
    print("[3/6] Reading baseline state from read path...")
    baseline = read_baseline(config, token, source_record, scout_entity, verbose=args.verbose)

    # Step 5: Execute operation
    print("[4/6] Executing operation under test...")
    operation_result = execute_operation(config, token, source_record, scout_entity, dry_run=args.dry_run, verbose=args.verbose)

    # Step 6: Poll for materialization
    print(f"[5/6] Polling read path for state change (timeout={POLL_TIMEOUT_SECONDS}s)...")
    if args.dry_run:
        final = baseline
        polls = 0
        elapsed = 0.0
    else:
        final, polls, elapsed = poll_for_state_change(config, token, source_record, scout_entity, baseline, verbose=args.verbose)

    # Step 7: Compare and emit verdict
    print("[6/6] Comparing before/after state...")
    diff = compare_states(baseline, final)
    passed = is_pass(diff, operation_result)

    verdict = {
        "verdict": "PASS" if passed else "FAIL",
        "operation": "{OPERATION_NAME}",
        "environment": args.env,
        "dry_run": args.dry_run,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "record_identifiers": {
            **source_record,
            "scout_id": scout_entity.get("scout_id"),
        },
        "baseline": baseline,
        "final": final,
        "diff": diff,
        "evidence": {
            "operation_status_code": operation_result.get("status_code"),
            "operation_response_body": operation_result.get("response_body"),
            "polls": polls,
            "elapsed_seconds": round(elapsed, 2),
            "poll_interval_seconds": POLL_INTERVAL_SECONDS,
            "poll_timeout_seconds": POLL_TIMEOUT_SECONDS,
        },
        "note": "Scout entity left in place. Identifier above for manual cleanup if needed.",
    }

    print("\n" + "=" * 60)
    print(f"VERDICT: {verdict['verdict']}")
    print("=" * 60)
    print(json.dumps(verdict, indent=2))

    sys.exit(0 if passed else 1)


if __name__ == "__main__":
    main()
