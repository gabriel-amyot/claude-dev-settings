        "read_path_url": "https://{READ_PATH_HOST_DEV}/{READ_PATH_ENDPOINT}",
        "gateway_url": "https://{GATEWAY_HOST_DEV}/graphql",
    },
    "uat": {
        "source_base_url": "https://{SOURCE_SYSTEM_HOST_UAT}",
