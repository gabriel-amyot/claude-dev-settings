    """
    Query the read path for the current state of the scout entity.
    Use the SAME path consumers/UI use. Do not shortcut to Datastore direct.
    Returns the state dict, or None if not found.
    """
    # === CONFIGURE: read path query ===
    # For EQS via Gateway (GraphQL):
    #   Use config["gateway_url"] with a GraphQL query.
    # For LLS REST:
    #   Use config["read_path_url"] with the entity identifier.

    state = _query_read_path(config, token, source_record, scout_entity, verbose)

    if verbose:
        print(f"[BASELINE] Current state: {json.dumps(state, indent=2)}")
    return state


